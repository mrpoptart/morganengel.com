{
  "name": "morganengel.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "emulator": "npx -y firebase-tools emulators:start --only firestore,auth,storage --project demo-morganengelcom",
    "emulator:seed": "npx -y firebase-tools emulators:exec --only firestore,auth,storage --project demo-morganengelcom 'node tests/seed.mjs'",
    "test:integration": "npx -y firebase-tools emulators:exec --only firestore,auth,storage --project demo-morganengelcom 'FIREBASE_EMULATOR=1 vitest run --config vitest.integration.config.ts'"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-youtube": "^2.27.2",
    "daisyui": "^5.5.19",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "leaflet": "^1.9.4",
    "next": "16.2.1",
    "node-html-parser": "^7.1.0",
    "novel": "^1.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.7"
  }
}
